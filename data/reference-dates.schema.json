{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/melliran/shahanshahi/reference-dates.schema.json",
  "title": "Shahanshahi golden test dates",
  "type": "object",
  "required": ["schema_version", "spec_id", "rows"],
  "properties": {
    "schema_version": { "type": "integer", "const": 1 },
    "spec_id": {
      "type": "string",
      "description": "Identifier matching SPEC.md revision (e.g. git tag or date)."
    },
    "rows": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["shahanshahi", "gregorian", "source"],
        "properties": {
          "shahanshahi": {
            "type": "object",
            "required": ["year", "month", "day"],
            "properties": {
              "year": { "type": "integer" },
              "month": { "type": "integer", "minimum": 1 },
              "day": { "type": "integer", "minimum": 1 }
            },
            "additionalProperties": false
          },
          "gregorian": {
            "type": "object",
            "required": ["year", "month", "day"],
            "properties": {
              "year": { "type": "integer" },
              "month": { "type": "integer", "minimum": 1, "maximum": 12 },
              "day": { "type": "integer", "minimum": 1, "maximum": 31 }
            },
            "additionalProperties": false
          },
          "source": {
            "type": "string",
            "description": "Primary citation or vetted table reference."
          },
          "notes": { "type": "string" }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
